# Path to Stockfish binary (default: look up "stockfish" on PATH)
STOCKFISH_PATH=stockfish

# Engine search: depth (used when ENGINE_TIME_LIMIT_S is unset)
ENGINE_DEPTH=14

# Optional: time limit per analysis in seconds (overrides depth if set)
# ENGINE_TIME_LIMIT_S=

# OpenAI-compatible SLM endpoint (Ollama default: http://127.0.0.1:11434/v1)
SLM_BASE_URL=http://127.0.0.1:11434/v1
SLM_MODEL=llama3.2

# Optional: bearer token for hosted OpenAI-compatible APIs
# SLM_API_KEY=

SLM_TIMEOUT_S=120

# Max tokens for the explanation completion
SLM_MAX_TOKENS=256
